{
  "manifest_version": 3,
  "name": "Barcode Lists",
  "version": "2.0",
  "description": "Store and manage barcode lists",
  "permissions": ["storage", "sidePanel"],
  "host_permissions": ["https://*.supabase.co/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Barcode Lists"
  },
  "side_panel": {
    "default_path": "popup.html"
  }
}
